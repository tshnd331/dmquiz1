# Discord bot token (Bot -> Token)
DISCORD_TOKEN=

# Discord application (client) ID
DISCORD_CLIENT_ID=

# Guild ID for fast (guild-scoped) slash command registration.
# Leave empty to register commands globally (can take up to ~1h to appear).
DISCORD_GUILD_ID=

# Prisma / SQLite database location
DATABASE_URL="file:./dev.db"

# Optional: Claude API key for the future ClaudeQuestionAnswerer.
# Not required for the current rule-based answerer.
CLAUDE_API_KEY=

# --- Feedback automation pipeline (optional) ---
# GitHub PAT with `issues` write scope; used to open Issues on approval.
GITHUB_TOKEN=
# Channel ID where admin approval embeds (approve/reject buttons) are posted.
ADMIN_CHANNEL_ID=
# Target repo for created Issues, "owner/name" form.
GITHUB_REPO=tshnd331/dmquiz1
# Fix-agent engine selector: "copilot" (default) | "claude".
FIX_AGENT=copilot
