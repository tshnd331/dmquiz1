# Discord bot token (Bot -> Token)
DISCORD_TOKEN=

# Discord application (client) ID
DISCORD_CLIENT_ID=

# Guild ID for fast (guild-scoped) slash command registration.
# Leave empty to register commands globally (can take up to ~1h to appear).
DISCORD_GUILD_ID=

# Prisma / SQLite database location
DATABASE_URL="file:./dev.db"

# Optional: Claude API key for the future ClaudeQuestionAnswerer.
# Not required for the current rule-based answerer.
CLAUDE_API_KEY=

# GitHub Personal Access Token for creating feedback issues automatically.
# Requires `repo` scope (or `public_repo` for public repositories).
GITHUB_TOKEN=
