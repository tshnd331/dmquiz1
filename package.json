{
  "name": "dmquiz1",
  "version": "0.1.0",
  "description": "Duel Masters card guessing quiz Discord bot",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "prisma:migrate": "prisma migrate dev",
    "prisma:generate": "prisma generate",
    "crawl": "tsx scripts/crawlDmwiki.ts",
    "deploy-commands": "tsx scripts/deployCommands.ts",
    "seed": "tsx scripts/seed.ts",
    "cards": "tsx scripts/cards.ts",
    "test": "tsx --test test/**/*.test.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.2.1",
    "cheerio": "^1.0.0",
    "discord.js": "^14.16.3",
    "dotenv": "^16.4.7"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "prisma": "^6.2.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
