// Prisma schema for the Duel Masters quiz bot.
// Datasource is SQLite for local development (see DATABASE_URL).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

/// A single Duel Masters card scraped from dmwiki.net.
/// Structured fields are best-effort; `rawText` is always preserved.
model Card {
  id           Int      @id @default(autoincrement())
  name         String   @unique
  civilization String?
  cost         Int?
  cardType     String?
  race         String?
  power        String? // kept as String because values like "+99999" / "∞" exist
  text         String?
  sourceUrl    String   @unique
  rawText      String
  fetchedAt    DateTime @default(now())

  feedback QuestionFeedback[]

  @@index([civilization])
  @@index([cardType])
}

/// User feedback on a bot answer, gated by an admin approval step.
/// status flows pending -> approved (GitHub Issue created) | rejected.
model QuestionFeedback {
  id     Int  @id @default(autoincrement())
  cardId Int
  card   Card @relation(fields: [cardId], references: [id], onDelete: Cascade)

  content String // 統合フリーテキスト（質問・本来の正解・理由）
  userId  String

  status      String @default("pending") // "pending" | "processing" | "approved" | "rejected"
  issueNumber Int? // GitHub Issue number created after approval

  adminComment String? // 承認/却下時に管理者が残したコメント

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([cardId])
  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

/// Aggregated accuracy stats per question pattern / rule category,
/// used to prioritise which answer rules to improve.
model FeedbackStats {
  id              Int    @id @default(autoincrement())
  questionPattern String
  ruleCategory    String // "civilization" | "cost" | "power" | "race" | "cardType"

  totalFeedback  Int   @default(0)
  incorrectCount Int   @default(0)
  accuracy       Float // 0.0 ~ 1.0

  lastUpdated DateTime @updatedAt

  @@unique([questionPattern, ruleCategory])
}

/// Tracks crawl progress so the batch can resume, skip done URLs,
/// and retry failures. `force` resets a target back to "pending".
model CrawlTarget {
  id        Int      @id @default(autoincrement())
  url       String   @unique
  type      String // "expansion" | "card"
  status    String   @default("pending") // pending | done | failed
  attempts  Int      @default(0)
  updatedAt DateTime @updatedAt

  @@index([type, status])
}
